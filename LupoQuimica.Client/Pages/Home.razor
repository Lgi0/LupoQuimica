@page "/"
@inject HttpClient Http

<PageTitle>Lupo Química | Início</PageTitle>

@* --- CARROSSEL --- *@
<div id="factoryCarousel" class="carousel slide carousel-fade shadow-lg mb-5" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#factoryCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#factoryCarousel" data-bs-slide-to="1"></button>
        <button type="button" data-bs-target="#factoryCarousel" data-bs-slide-to="2"></button>
    </div>

    <div class="carousel-inner rounded-bottom-4">
        @* Slide 1: Fábrica *@
        <div class="carousel-item active" data-bs-interval="5000">
            <div class="overlay"></div>
            <img src="https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?auto=format&fit=crop&q=80&w=1920" class="d-block w-100 banner-img" alt="Fábrica Lupo Química">
            <div class="carousel-caption text-start">
                <h1 class="display-4 fw-bold text-white">Lupo Química</h1>
                <p class="lead">Excelência e tecnologia em produtos industriais.</p>
            </div>
        </div>

        @* Slide 2: Empório da Limpeza (Com o seu logo!) *@
        <div class="carousel-item" data-bs-interval="5000">
            <div class="overlay-blue"></div>
            <img src="https://images.unsplash.com/photo-1513530534585-c7b1394c6d51?auto=format&fit=crop&q=80&w=1920" class="d-block w-100 banner-img" alt="Emporio da Limpeza">
            <div class="carousel-caption text-center">
                @* Aqui chamamos o logo que você me enviou *@
                <img src="images/logo-emporio.png" alt="Logo Empório" style="max-width: 300px; margin-bottom: 20px;" />
                <p class="lead fw-bold">Nossa loja física com a linha completa para você.</p>
                <a href="https://www.google.com/maps" target="_blank" class="btn btn-light btn-lg text-primary fw-bold">Ver Localização</a>
            </div>
        </div>

        @* Slide 3: Qualidade *@
        <div class="carousel-item" data-bs-interval="5000">
            <div class="overlay"></div>
            <img src="https://images.unsplash.com/photo-1532187875605-2fe35851142b?auto=format&fit=crop&q=80&w=1920" class="d-block w-100 banner-img" alt="Laboratório">
            <div class="carousel-caption text-end">
                <h1 class="display-4 fw-bold text-white">Qualidade Certificada</h1>
                <p class="lead">Controle rigoroso em cada lote produzido.</p>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <h2 class="text-center mb-4 text-primary fw-bold">Nossos Produtos</h2>
    @* O seu código do @foreach (var produto in produtos) entra aqui embaixo *@
</div>

<style>
    .banner-img {
        height: 550px;
        object-fit: cover;
    }

    .overlay {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        background: linear-gradient(to right, rgba(0,0,0,0.7), transparent);
        z-index: 1;
    }

    .overlay-blue {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        background: linear-gradient(rgba(0, 123, 255, 0.4), rgba(0, 0, 0, 0.6));
        z-index: 1;
    }

    .carousel-caption {
        z-index: 2;
        bottom: 20%;
    }
</style>