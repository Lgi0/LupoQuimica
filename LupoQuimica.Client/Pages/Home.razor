@page "/"
@using LupoQuimica.Shared
@inject HttpClient Http

<PageTitle>Lupo Química | Catálogo</PageTitle>

@* --- CARROSSEL --- *@
<div id="factoryCarousel" class="carousel slide carousel-fade shadow-lg mb-5" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#factoryCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#factoryCarousel" data-bs-slide-to="1"></button>
    </div>
    <div class="carousel-inner rounded-bottom-4">

        @* Slide 1: Fábrica *@
        <div class="carousel-item active" data-bs-interval="5000">
            <img src="https://thumbs.dreamstime.com/b/industrial-chemical-processing-manufacturing-facility-laboratory-setup-clean-environment-close-up-view-supply-chain-dynamics-350748109.jpg"
                 class="d-block w-100 banner-img" alt="Fábrica Lupo Química">
            <div class="overlay"></div>
            <div class="carousel-caption d-none d-md-block text-start">
                <h1 class="display-4 fw-bold">Lupo Química</h1>
                <p class="lead">Excelência e tecnologia em produtos industriais.</p>
                <a href="#produtos" class="btn btn-primary btn-lg rounded-pill px-4">Conheça nossos produtos</a>
            </div>
        </div>

        @* Slide 2: Empório da Limpeza *@
        <div class="carousel-item" data-bs-interval="5000">
            <img src="images/fundo-neutro-premium.jpeg" class="d-block w-100 banner-img" alt="Emporio da Limpeza">
            <div class="overlay-blue"></div>
            <div class="carousel-caption d-none d-md-block">
                <img src="images/logo-emporio2.png" alt="Logo Empório" class="logo-flutuante mb-3">
                <h2 class="display-6 fw-bold text-dark mb-1">Do Laboratório ao Varejo</h2>
                <p class="lead text-dark fw-normal">Sua linha completa de produtos de limpeza, direto da fábrica.</p>
                <a href="https://instagram.com/emporiodalimpezasp" target="_blank"
                   class="btn btn-outline-primary btn-lg rounded-pill px-4 mt-3 shadow fw-bold">
                    Siga no Instagram
                </a>
            </div>
        </div>

    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#factoryCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#factoryCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>
</div>

<div class="container mt-4" id="produtos">
    @* --- FILTROS --- *@
    <div class="row g-3 mb-5 justify-content-center">
        <div class="col-md-5">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-success"></i></span>
                <input type="text" class="form-control border-start-0" placeholder="O que você procura?"
                       @bind="filtroTexto" @bind:event="oninput" />
            </div>
        </div>
        <div class="col-md-3">
            <select class="form-select shadow-sm" @bind="categoriaSelecionadaId">
                <option value="0">Todas as Categorias</option>
                @foreach (var cat in categorias)
                {
                    <option value="@cat.Id">@cat.Nome</option>
                }
            </select>
        </div>
    </div>

    @* --- PRODUTOS --- *@
    @if (produtos == null)
    {
        <div class="text-center p-5">
            <div class="spinner-border text-success" role="status"></div>
            <p class="mt-2 text-muted">Carregando catálogo...</p>
        </div>
    }
    else if (!ProdutosFiltrados.Any())
    {
        <div class="text-center p-5">
            <i class="bi bi-box-seam text-muted" style="font-size: 3rem;"></i>
            <p class="mt-3 text-muted">Nenhum produto encontrado.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var produto in ProdutosFiltrados)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 product-card" style="border-radius: 15px; transition: transform 0.2s;">
                        <div class="p-3 text-center bg-light" style="border-radius: 15px 15px 0 0;">
                            <img src="@produto.ImagemUrl" class="card-img-top" style="height: 180px; object-fit: contain;" alt="@produto.Nome">
                        </div>
                        <div class="card-body">
                            <span class="badge bg-success bg-opacity-10 text-success mb-2">@ObterNomeCategoria(produto.CategoriaId)</span>
                            <h5 class="card-title fw-bold text-dark">@produto.Nome</h5>
                            <p class="card-text text-muted small mb-3"><strong>Marca:</strong> @produto.Marca</p>
                            <a href="detalhes/@produto.Id" class="btn btn-success w-100 rounded-pill fw-bold">Ver Detalhes</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

/* Altura fixa do banner */
.banner-img {
    height: 520px;
    object-fit: cover;
    object-position: center;
}

/* Overlay escuro para o Slide 1 */
.overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    z-index: 1;
}

/* Overlay azul semitransparente para o Slide 2 */
.overlay-blue {
    position: absolute;
    inset: 0;
    background: rgba(200, 220, 255, 0.55);
    z-index: 1;
}

/* O caption precisa ficar acima dos overlays */
.carousel-caption {
    z-index: 2;
    bottom: 15%;
}

/* Logo no slide 2 */
.logo-flutuante {
    max-height: 100px;
    width: auto;
    display: block;
    margin: 0 auto;
}

@code {
    private List<Produto> produtos;
    private List<Categoria> categorias = new();
    private string filtroTexto = "";
    private int categoriaSelecionadaId = 0;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            produtos = await Http.GetFromJsonAsync<List<Produto>>("api/produtos");
            categorias = await Http.GetFromJsonAsync<List<Categoria>>("api/categorias") ?? new();
        }
        catch { produtos = new List<Produto>(); }
    }

    private IEnumerable<Produto> ProdutosFiltrados =>
        produtos?.Where(p =>
            (categoriaSelecionadaId == 0 || p.CategoriaId == categoriaSelecionadaId) &&
            (string.IsNullOrWhiteSpace(filtroTexto) || p.Nome.Contains(filtroTexto, StringComparison.OrdinalIgnoreCase)))
        ?? new List<Produto>();

    private string ObterNomeCategoria(int id) => categorias.FirstOrDefault(c => c.Id == id)?.Nome ?? "Geral";
}