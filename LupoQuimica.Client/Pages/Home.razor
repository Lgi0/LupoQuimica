@page "/"
@using LupoQuimica.Shared
@inject HttpClient Http

@* --- SEÇÃO DO CARROSSEL --- *@
<div class="container-fluid p-0 mb-5">
    <SfCarousel AnimationEffect="CarouselAnimationEffect.Fade" AutoPlay="true">
        <CarouselItem>
            <div class="item-container">
                <img src="https://thumbs.dreamstime.com/b/industrial-chemical-processing-manufacturing-facility-laboratory-setup-clean-environment-close-up-view-supply-chain-dynamics-350748109.jpg" class="d-block w-100 banner-img" />
                <div class="caption-overlay">
                    <h1 class="display-4 fw-bold">Lupo Química</h1>
                    <p class="lead">Inovação e qualidade em cada solução industrial.</p>
                </div>
            </div>
        </CarouselItem>
        @* Adicione mais CarouselItem aqui conforme precisar *@
    </SfCarousel>
</div>

<style>
    .banner-img {
        height: 500px;
        object-fit: cover;
        filter: brightness(0.6); /* Deixa a imagem mais escura pro texto brilhar */
    }

    .item-container {
        position: relative;
    }

    .caption-overlay {
        position: absolute;
        top: 50%;
        left: 10%;
        transform: translateY(-50%);
        color: white;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
    }
</style>

<div class="container mt-4">

    @* --- BARRA DE FILTROS --- *@
    <div class="row g-3 mb-5 justify-content-center">
        <div class="col-md-5">
            <div class="input-group shadow-sm">
                <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-success"></i></span>
                <input type="text" class="form-control border-start-0" placeholder="O que você procura?"
                       @bind="filtroTexto" @bind:event="oninput" />
            </div>
        </div>
        <div class="col-md-3">
            <select class="form-select shadow-sm" @bind="categoriaSelecionadaId">
                <option value="0">Todas as Categorias</option>
                @foreach (var cat in categorias)
                {
                    <option value="@cat.Id">@cat.Nome</option>
                }
            </select>
        </div>
    </div>

    @* --- LISTAGEM DE PRODUTOS --- *@
    @if (produtos == null)
    {
        <div class="text-center p-5">
            <div class="spinner-border text-success" role="status"></div>
            <p class="mt-2 text-muted">Carregando catálogo...</p>
        </div>
    }
    else if (!ProdutosFiltrados.Any())
    {
        <div class="text-center p-5">
            <i class="bi bi-box-seam text-muted" style="font-size: 3rem;"></i>
            <p class="mt-3 text-muted">Nenhum produto encontrado para essa busca.</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var produto in ProdutosFiltrados)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 product-card" style="border-radius: 15px; transition: transform 0.2s;">
                        <div class="p-3 text-center bg-light" style="border-radius: 15px 15px 0 0;">
                            <img src="@produto.ImagemUrl" class="card-img-top"
                                 style="height: 180px; object-fit: contain;"
                                 alt="@produto.Nome">
                        </div>
                        <div class="card-body">
                            <span class="badge bg-success bg-opacity-10 text-success mb-2">
                                @ObterNomeCategoria(produto.CategoriaId)
                            </span>
                            <h5 class="card-title fw-bold text-dark">@produto.Nome</h5>
                            <p class="card-text text-muted small mb-3">
                                <strong>Marca:</strong> @produto.Marca
                            </p>
                            <a href="detalhes/@produto.Id" class="btn btn-success w-100 rounded-pill fw-bold">
                                Ver Detalhes
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .product-card:hover {
        transform: translateY(-5px);
    }
</style>

@code {
    private List<Produto> produtos;
    private List<Categoria> categorias = new();
    private string filtroTexto = "";
    private int categoriaSelecionadaId = 0;

    protected override async Task OnInitializedAsync()
    {
        produtos = await Http.GetFromJsonAsync<List<Produto>>("api/produtos");
        categorias = await Http.GetFromJsonAsync<List<Categoria>>("api/categorias");
    }

    private IEnumerable<Produto> ProdutosFiltrados =>
        produtos?.Where(p =>
            (categoriaSelecionadaId == 0 || p.CategoriaId == categoriaSelecionadaId) &&
            (string.IsNullOrWhiteSpace(filtroTexto) ||
             p.Nome.Contains(filtroTexto, StringComparison.OrdinalIgnoreCase) ||
             p.Marca.Contains(filtroTexto, StringComparison.OrdinalIgnoreCase))
        ) ?? new List<Produto>();

    private string ObterNomeCategoria(int id)
        => categorias.FirstOrDefault(c => c.Id == id)?.Nome ?? "Geral";
}